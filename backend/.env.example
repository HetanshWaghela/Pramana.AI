# ══════════════════════════════════════════════════════════════════════════════
# Pramana.ai - Environment Configuration
# Copy this file to .env and fill in your API keys
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED - AI Provider
# Get your API key from: https://console.groq.com/keys
# ──────────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# REQUIRED - Web Search (for Deep Researcher agent)
# Get your API key from: https://serpapi.com/
# ──────────────────────────────────────────────────────────────────────────────
SERPAPI_API_KEY=your_serpapi_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Monitoring & Observability
# Get your API key from: https://smith.langchain.com/
# ──────────────────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_api_key_here

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL - Production Infrastructure
# Only required for Docker/production deployment
# ──────────────────────────────────────────────────────────────────────────────
REDIS_URI=redis://localhost:6379
POSTGRES_URI=postgres://pramana:pramana_secure_password@localhost:5432/pramana

# ──────────────────────────────────────────────────────────────────────────────
# OPTIONAL - MCP Server Configuration
# Model Context Protocol for external tool integrations
# ──────────────────────────────────────────────────────────────────────────────

# Filesystem MCP Server (file operations)
MCP_FILESYSTEM_ENABLED=true
MCP_FILESYSTEM_PATH=/app/workspace

# Brave Search MCP Server (alternative to SerpAPI)
# Get your API key from: https://brave.com/search/api/
MCP_BRAVE_SEARCH_ENABLED=false
BRAVE_API_KEY=your_brave_api_key_here

# ══════════════════════════════════════════════════════════════════════════════
# Pramana.ai - Master biomedical evidence. Without the silos.
# ══════════════════════════════════════════════════════════════════════════════
